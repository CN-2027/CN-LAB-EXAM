import socket

SERVER_HOST = "127.0.0.1"
SERVER_PORT = 9999

sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.settimeout(3)

print("Type messages. Ctrl+C to exit.")

while True:
    msg = input("You: ")
    sock.sendto(msg.encode("utf-8"), (SERVER_HOST, SERVER_PORT))

    try:
        data, addr = sock.recvfrom(2048)
        print("Server:", data.decode("utf-8", errors="replace"))
    except socket.timeout:
        print("No response (timeout). Is the server running?")

udp_server.py
import socket

HOST = "127.0.0.1"   # listen on localhost inside WSL
PORT = 9999          # UDP port

sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.bind((HOST, PORT))

print(f"UDP Server listening on {HOST}:{PORT}")

while True:
    data, addr = sock.recvfrom(2048)  # (bytes, (ip, port))
    msg = data.decode("utf-8", errors="replace")
    print(f"Received from {addr}: {msg}")

    reply = f"ACK: {msg}"
    sock.sendto(reply.encode("utf-8"), addr)



