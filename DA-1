        if not chunk:
            raise ConnectionError("closed")
        data += chunk
    return json.loads(data.decode())

def load_server_pubkey():
    with open("server_signing_pub.pem", "rb") as f:
        return serialization.load_pem_public_key(f.read())

def hkdf_key(shared_secret: bytes, salt: bytes) -> bytes:
    return HKDF(
        algorithm=hashes.SHA256(),
        length=32,
        salt=salt,
        info=b"secure-socket-demo-v1",
    ).derive(shared_secret)

def main():
    server_verify_pk = load_server_pubkey()

    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.connect((SERVER_HOST, SERVER_PORT))
    print(f"[client] connected to {SERVER_HOST}:{SERVER_PORT}")

    # --- Receive SERVER_HELLO and verify signature ---
    msg = recv_frame(sock)
    if msg.get("type") != "SERVER_HELLO":
        raise ValueError("bad handshake")

    server_eph_pk = bytes.fromhex(msg["server_eph_pk"])
    server_nonce = bytes.fromhex(msg["server_nonce"])
    sig = bytes.fromhex(msg["sig"])

    # Verify authenticity of server ephemeral key
    try:
        server_verify_pk.verify(sig, server_eph_pk + server_nonce)
    except Exception:
        raise RuntimeError("SERVER AUTH FAILED (possible MITM)")

    # --- Send CLIENT_HELLO ---
    client_eph_sk = x25519.X25519PrivateKey.generate()
    client_eph_pk = client_eph_sk.public_key().public_bytes(
        encoding=serialization.Encoding.Raw,
        format=serialization.PublicFormat.Raw
    )
    client_nonce = os.urandom(16)

    send_frame(sock, {
        "type": "CLIENT_HELLO",
        "client_eph_pk": client_eph_pk.hex(),
        "client_nonce": client_nonce.hex()
    })

    server_pub = x25519.X25519PublicKey.from_public_bytes(server_eph_pk)
    shared = client_eph_sk.exchange(server_pub)

    salt = server_nonce + client_nonce
    key = hkdf_key(shared, salt)
    aead = AESGCM(key)

    print("[client] handshake complete, secure channel ready")
    print("Type messages. 'quit' to end.\n")

    send_counter = 0
    recv_counter = -1

    while True:
        text = input("You: ").strip()
        pt = text.encode()

        nonce = send_counter.to_bytes(12, "big")
        ct = aead.encrypt(nonce, pt, None)

        send_frame(sock, {
            "type": "DATA",
            "counter": send_counter,
            "nonce": nonce.hex(),
            "ciphertext": ct.hex()
        })
        send_counter += 1

        if text.lower() == "quit":
            break

        # wait for server reply
        resp = recv_frame(sock)
        if resp.get("type") != "DATA":
            continue

        counter = resp["counter"]
        if counter <= recv_counter:
            print("[client] replay detected, dropping")
            continue
        recv_counter = counter

        r_nonce = bytes.fromhex(resp["nonce"])
        r_ct = bytes.fromhex(resp["ciphertext"])

        try:
            r_pt = aead.decrypt(r_nonce, r_ct, None)
            print("Server:", r_pt.decode(errors="replace"))
        except Exception:
            print("[client] auth failed / tampered packet")

    sock.close()

