#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <unistd.h>
#include <arpa/inet.h>

#define PORT 8080
#define BUF_SIZE 1024

int main() {
    int sock;
    struct sockaddr_in server_addr;
    char send_buf[BUF_SIZE], recv_buf[BUF_SIZE];

    // 1) Create socket
    sock = socket(AF_INET, SOCK_STREAM, 0);
    if (sock < 0) {
        perror("socket");
        return 1;
    }

    // 2) Server address
    server_addr.sin_family = AF_INET;
    server_addr.sin_port = htons(PORT);

    // connect to localhost (WSL)
    if (inet_pton(AF_INET, "127.0.0.1", &server_addr.sin_addr) <= 0) {
        perror("inet_pton");
        close(sock);
        return 1;
    }

    // 3) Connect
    if (connect(sock, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {
        perror("connect");
        close(sock);
        return 1;
    }

    printf("Connected to server 127.0.0.1:%d\n", PORT);
    printf("Type 'exit' to close.\n");

    while (1) {
        // Send message to server
        printf("You (Client): ");
        fflush(stdout);

        if (!fgets(send_buf, BUF_SIZE, stdin)) break;
        send_buf[strcspn(send_buf, "\n")] = '\0';

        if (send(sock, send_buf, strlen(send_buf), 0) < 0) {
            perror("send");
            break;
        }

        if (strncmp(send_buf, "exit", 4) == 0) {
            printf("Client ended chat.\n");
            break;
        }

        // Receive server reply
        memset(recv_buf, 0, BUF_SIZE);
        int n = recv(sock, recv_buf, BUF_SIZE - 1, 0);
        if (n <= 0) {
            printf("Server disconnected.\n");
            break;
        }
        recv_buf[n] = '\0';
        printf("Server: %s\n", recv_buf);

        if (strncmp(recv_buf, "exit", 4) == 0) {
            printf("Server ended chat.\n");
            break;
        }
    }

    close(sock);
    return 0;
}



