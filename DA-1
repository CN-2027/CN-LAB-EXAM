#define LINE_MAX 4096
#define DATA_BUFSZ 8192

static void die(const char *msg) {
    perror(msg);
    exit(1);
}

static int send_all(int fd, const void *buf, size_t len) {
    const char *p = (const char*)buf;
    size_t sent = 0;
    while (sent < len) {
        ssize_t n = send(fd, p + sent, len - sent, 0);
        if (n < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        sent += (size_t)n;
    }
    return 0;
}

static int send_line(int fd, const char *line) {
    return send_all(fd, line, strlen(line));
}

static int recv_line(int fd, char *out, size_t out_sz) {
    size_t used = 0;
    while (1) {
        if (used + 1 >= out_sz) return -2;
        char c;
        ssize_t n = recv(fd, &c, 1, 0);
        if (n == 0) return 0;
        if (n < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        out[used++] = c;
        out[used] = '\0';
        if (c == '\n') return 1;
    }
}

static int connect_tcp(const char *ip, uint16_t port) {
    int s = socket(AF_INET, SOCK_STREAM, 0);
    if (s < 0) return -1;

    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    if (inet_pton(AF_INET, ip, &addr.sin_addr) != 1) {
        close(s);
        return -1;
    }
    if (connect(s, (struct sockaddr*)&addr, sizeof(addr)) < 0) {
        close(s);
        return -1;
    }
    return s;
}

static long long file_size(const char *path) {
    struct stat st;
    if (stat(path, &st) != 0) return -1;
    return (long long)st.st_size;
}

static int do_put(int control_fd, const char *server_ip, const char *path) {
    const char *fname = strrchr(path, '/');
    fname = fname ? fname + 1 : path;

    long long sz = file_size(path);
    if (sz < 0) {
        printf("PUT: can't stat file: %s\n", path);
        return 0;
    }

    char cmd[512];
    snprintf(cmd, sizeof(cmd), "STOR %s %lld\n", fname, sz);
    if (send_line(control_fd, cmd) < 0) {
        printf("PUT: failed to send STOR\n");
        return 0;
    }

    char resp[LINE_MAX];
    if (recv_line(control_fd, resp, sizeof(resp)) <= 0) {
        printf("PUT: no response\n");
        return 0;
    }

    // Expect: 150 PASV <port>
    unsigned pasv_port;
    if (sscanf(resp, "150 PASV %u", &pasv_port) != 1) {
        printf("PUT: server refused: %s", resp);
        return 0;
    }

    int data_fd = connect_tcp(server_ip, (uint16_t)pasv_port);
    if (data_fd < 0) {
        printf("PUT: can't connect data port %u\n", pasv_port);
        return 0;
    }

    FILE *fp = fopen(path, "rb");
    if (!fp) {
        close(data_fd);
        printf("PUT: can't open file\n");
        return 0;
    }

    char buf[DATA_BUFSZ];
    long long remaining = sz;
    while (remaining > 0) {
        size_t r = fread(buf, 1, (remaining > DATA_BUFSZ) ? DATA_BUFSZ : (size_t)remaining, fp);
        if (r == 0) break;
        if (send_all(data_fd, buf, r) < 0) {
            fclose(fp);
            close(data_fd);
            printf("PUT: send failed\n");
            return 0;
        }
        remaining -= (long long)r;
    }

    fclose(fp);
    close(data_fd);

    // Final status
    if (recv_line(control_fd, resp, sizeof(resp)) > 0) {
        printf("%s", resp);
        return (strncmp(resp, "226", 3) == 0);
    }
    printf("PUT: missing final reply\n");
    return 0;
}

static int do_get(int control_fd, const char *server_ip, const char *fname) {
    char cmd[512];
    snprintf(cmd, sizeof(cmd), "RETR %s\n", fname);
    if (send_line(control_fd, cmd) < 0) {
        printf("GET: failed to send RETR\n");
        return 0;
    }

    char resp[LINE_MAX];
    if (recv_line(control_fd, resp, sizeof(resp)) <= 0) {
        printf("GET: no response\n");
        return 0;
    }

    // Expect: 150 PASV <port> <size>
    unsigned pasv_port;
    long long sz;
    if (sscanf(resp, "150 PASV %u %lld", &pasv_port, &sz) != 2) {
        printf("GET: server refused: %s", resp);
        return 0;
    }

    int data_fd = connect_tcp(server_ip, (uint16_t)pasv_port);
    if (data_fd < 0) {
        printf("GET: can't connect data port %u\n", pasv_port);
        return 0;
    }

    // Save as downloaded_<fname>
    char outname[512];
    snprintf(outname, sizeof(outname), "downloaded_%s", fname);

    FILE *fp = fopen(outname, "wb");
    if (!fp) {
        close(data_fd);
        printf("GET: can't open output file\n");
        return 0;
    }

    char buf[DATA_BUFSZ];
    long long remaining = sz;
    while (remaining > 0) {
        ssize_t chunk = (remaining > DATA_BUFSZ) ? DATA_BUFSZ : (ssize_t)remaining;
        ssize_t n = recv(data_fd, buf, chunk, 0);
        if (n <= 0) {
            fclose(fp);
            close(data_fd);
            printf("GET: data connection closed early\n");
            return 0;
        }
        fwrite(buf, 1, (size_t)n, fp);
        remaining -= n;
    }

    fclose(fp);
    close(data_fd);

    // Final status
    if (recv_line(control_fd, resp, sizeof(resp)) > 0) {
        printf("%s", resp);
        if (strncmp(resp, "226", 3) == 0) {
            printf("Saved to %s (%lld bytes)\n", outname, sz);
            return 1;
        }
        return 0;
    }

    printf("GET: missing final reply\n");
    return 0;
}

int main(int argc, char **argv) {
    if (argc < 3) {
        fprintf(stderr, "Usage: %s <server_ip> <port>\n", argv[0]);
        return 1;
    }
    const char *server_ip = argv[1];
    uint16_t port = (uint16_t)atoi(argv[2]);

    int control = connect_tcp(server_ip, port);
    if (control < 0) die("connect");

    printf("Connected to %s:%u\n", server_ip, port);
    printf("Commands:\n");
    printf("  (type any text) -> chat\n");
    printf("  /put <path>     -> upload file\n");
    printf("  /get <name>     -> download file\n");
    printf("  /quit           -> exit\n\n");

    // Read server greeting
    char line[LINE_MAX];
    if (recv_line(control, line, sizeof(line)) > 0) {
        printf("%s", line);
    }

    fd_set rfds;

    while (1) {
        FD_ZERO(&rfds);
        FD_SET(control, &rfds);
        FD_SET(STDIN_FILENO, &rfds);
        int maxfd = (control > STDIN_FILENO) ? control : STDIN_FILENO;

        int r = select(maxfd + 1, &rfds, NULL, NULL, NULL);
        if (r < 0) {
            if (errno == EINTR) continue;
            die("select");
        }

        // Incoming from server
        if (FD_ISSET(control, &rfds)) {
            int rr = recv_line(control, line, sizeof(line));
            if (rr == 0) {
                printf("Server disconnected.\n");
                break;
            }
            if (rr < 0) {
                printf("recv error.\n");
                break;
            }

            if (strncmp(line, "MSG ", 4) == 0) {
                printf("Server: %s", line + 4);
            } else {
                // status lines (220/226/5xx etc.)
                printf("%s", line);
            }
        }

        // User input
        if (FD_ISSET(STDIN_FILENO, &rfds)) {
            if (!fgets(line, sizeof(line), stdin)) break;

            if (strncmp(line, "/quit", 5) == 0) {
                send_line(control, "QUIT\n");
                break;
            } else if (strncmp(line, "/put ", 5) == 0) {
                char path[512];
                if (sscanf(line + 5, "%511s", path) == 1) {
                    do_put(control, server_ip, path);
                } else {
                    printf("Usage: /put <path>\n");
                }
            } else if (strncmp(line, "/get ", 5) == 0) {
                char fname[256];
                if (sscanf(line + 5, "%255s", fname) == 1) {
                    do_get(control, server_ip, fname);
                } else {
                    printf("Usage: /get <name>\n");
                }
            } else {
                // normal chat
                char out[LINE_MAX + 8];
                snprintf(out, sizeof(out), "MSG %s", line);
                if (send_line(control, out) < 0) {
                    printf("Send failed.\n");
                    break;
                }
            }
        }
    }

    close(control);
    return 0;
}


