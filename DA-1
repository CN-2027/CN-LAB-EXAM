#define _POSIX_C_SOURCE 200809L
#include <arpa/inet.h>
#include <errno.h>
#include <netinet/in.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/select.h>
#include <sys/socket.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <unistd.h>

#define LINE_MAX 4096
#define DATA_BUFSZ 8192

static void die(const char *msg) {
    perror(msg);
    exit(1);
}

static int send_all(int fd, const void *buf, size_t len) {
    const char *p = (const char*)buf;
    size_t sent = 0;
    while (sent < len) {
        ssize_t n = send(fd, p + sent, len - sent, 0);
        if (n < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        sent += (size_t)n;
    }
    return 0;
}

static int send_line(int fd, const char *line) {
    return send_all(fd, line, strlen(line));
}

// Read a line ending in '\n' from socket fd into out (null-terminated).
// Returns: 1 = success, 0 = peer closed, -1 = error, -2 = line too long
static int recv_line(int fd, char *out, size_t out_sz) {
    size_t used = 0;
    while (1) {
        if (used + 1 >= out_sz) return -2;
        char c;
        ssize_t n = recv(fd, &c, 1, 0);
        if (n == 0) return 0;
        if (n < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        out[used++] = c;
        out[used] = '\0';
        if (c == '\n') return 1;
    }
}

// Very basic filename safety: only allow plain names (no /, \, ..)
static int safe_filename(const char *name) {
    if (!name || !*name) return 0;
    if (strstr(name, "..")) return 0;
    if (strchr(name, '/')) return 0;
    if (strchr(name, '\\')) return 0;
    return 1;
}

static int make_listener(uint16_t port, uint16_t *out_port) {
    int s = socket(AF_INET, SOCK_STREAM, 0);
    if (s < 0) return -1;

    int yes = 1;
    setsockopt(s, SOL_SOCKET, SO_REUSEADDR, &yes, sizeof(yes));

    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_addr.s_addr = htonl(INADDR_ANY);
    addr.sin_port = htons(port);

    if (bind(s, (struct sockaddr*)&addr, sizeof(addr)) < 0) {
        close(s);
        return -1;
    }
    if (listen(s, 1) < 0) {
        close(s);
        return -1;
    }

    if (out_port) {
        socklen_t alen = sizeof(addr);
        if (getsockname(s, (struct sockaddr*)&addr, &alen) == 0) {
            *out_port = ntohs(addr.sin_port);
        } else {
            *out_port = port;
        }
    }
    return s;
}

static int accept_one(int listener) {
    struct sockaddr_in caddr;
    socklen_t clen = sizeof(caddr);
    int c = accept(listener, (struct sockaddr*)&caddr, &clen);
    return c;
}

static int handle_stor(int control_fd, const char *filename, long long size) {
    if (!safe_filename(filename) || size < 0) {
        send_line(control_fd, "550 Invalid filename/size\n");
        return 0;
    }

    mkdir("server_files", 0755);

    // Create PASV data listener on ephemeral port (0).
    uint16_t pasv_port = 0;
    int data_listener = make_listener(0, &pasv_port);
    if (data_listener < 0) {
        send_line(control_fd, "425 Can't open data connection\n");
        return 0;
    }

    char resp[128];
    snprintf(resp, sizeof(resp), "150 PASV %u\n", pasv_port);
    if (send_line(control_fd, resp) < 0) {
        close(data_listener);
        return 0;
    }

    int data_fd = accept_one(data_listener);
    close(data_listener);
    if (data_fd < 0) {
        send_line(control_fd, "425 Data accept failed\n");
        return 0;
    }

    char path[512];
    snprintf(path, sizeof(path), "server_files/%s", filename);
    FILE *fp = fopen(path, "wb");
    if (!fp) {
        close(data_fd);
        send_line(control_fd, "550 Can't open file for write\n");
        return 0;
    }

    long long remaining = size;
    char buf[DATA_BUFSZ];

    while (remaining > 0) {
        ssize_t chunk = (remaining > DATA_BUFSZ) ? DATA_BUFSZ : (ssize_t)remaining;
        ssize_t n = recv(data_fd, buf, chunk, 0);
        if (n <= 0) {
            fclose(fp);
            close(data_fd);
            send_line(control_fd, "426 Connection closed; transfer aborted\n");
            return 0;
        }
        fwrite(buf, 1, (size_t)n, fp);
        remaining -= n;
    }

    fclose(fp);
    close(data_fd);

    snprintf(resp, sizeof(resp), "226 Stored %s\n", filename);
    send_line(control_fd, resp);
    return 1;
}

static int handle_retr(int control_fd, const char *filename) {
    if (!safe_filename(filename)) {
        send_line(control_fd, "550 Invalid filename\n");
        return 0;
    }

    char path[512];
    snprintf(path, sizeof(path), "server_files/%s", filename);

    FILE *fp = fopen(path, "rb");
    if (!fp) {
        send_line(control_fd, "550 File not found\n");
        return 0;
    }

    // Find file size
    if (fseek(fp, 0, SEEK_END) != 0) {
        fclose(fp);
        send_line(control_fd, "550 Can't read file\n");
        return 0;
    }
    long long size = ftell(fp);
    fseek(fp, 0, SEEK_SET);

    uint16_t pasv_port = 0;
    int data_listener = make_listener(0, &pasv_port);
    if (data_listener < 0) {
        fclose(fp);
        send_line(control_fd, "425 Can't open data connection\n");
        return 0;
    }

    char resp[160];
    snprintf(resp, sizeof(resp), "150 PASV %u %lld\n", pasv_port, size);
    if (send_line(control_fd, resp) < 0) {
        fclose(fp);
        close(data_listener);
        return 0;
    }

    int data_fd = accept_one(data_listener);
    close(data_listener);
    if (data_fd < 0) {
        fclose(fp);
        send_line(control_fd, "425 Data accept failed\n");
        return 0;
    }

    char buf[DATA_BUFSZ];
    long long remaining = size;
    while (remaining > 0) {
        size_t r = fread(buf, 1, (remaining > DATA_BUFSZ) ? DATA_BUFSZ : (size_t)remaining, fp);
        if (r == 0) break;
        if (send_all(data_fd, buf, r) < 0) {
            fclose(fp);
            close(data_fd);
            send_line(control_fd, "426 Connection closed; transfer aborted\n");
            return 0;
        }
        remaining -= (long long)r;
    }

    fclose(fp);
    close(data_fd);

    snprintf(resp, sizeof(resp), "226 Sent %s\n", filename);
    send_line(control_fd, resp);
    return 1;
}

int main(int argc, char **argv) {
    uint16_t port = 2121;
    if (argc >= 2) port = (uint16_t)atoi(argv[1]);

    int listener = make_listener(port, NULL);
    if (listener < 0) die("listen socket");

    printf("Server listening on 0.0.0.0:%u\n", port);
    printf("Chat: type and press Enter to send.\n");
    printf("Commands received from client:\n");
    printf("  MSG <text>\\n\n  STOR <name> <size>\\n\n  RETR <name>\\n\n  QUIT\\n\n");

    int client = accept_one(listener);
    if (client < 0) die("accept");
    printf("Client connected.\n");

    // Send greeting
    send_line(client, "220 Welcome to mini-FTP-chat server\n");

    fd_set rfds;
    char line[LINE_MAX];

    while (1) {
        FD_ZERO(&rfds);
        FD_SET(client, &rfds);
        FD_SET(STDIN_FILENO, &rfds);

        int maxfd = (client > STDIN_FILENO) ? client : STDIN_FILENO;
        int r = select(maxfd + 1, &rfds, NULL, NULL, NULL);
        if (r < 0) {
            if (errno == EINTR) continue;
            die("select");
        }

        // Incoming from client
        if (FD_ISSET(client, &rfds)) {
            int rr = recv_line(client, line, sizeof(line));
            if (rr == 0) {
                printf("Client disconnected.\n");
                break;
            }
            if (rr < 0) {
                printf("recv_line error.\n");
                break;
            }

            // Parse commands
            if (strncmp(line, "MSG ", 4) == 0) {
                printf("Client: %s", line + 4);
            } else if (strncmp(line, "STOR ", 5) == 0) {
                char fname[256];
                long long fsz;
                if (sscanf(line + 5, "%255s %lld", fname, &fsz) == 2) {
                    printf("Client wants upload: %s (%lld bytes)\n", fname, fsz);
                    handle_stor(client, fname, fsz);
                } else {
                    send_line(client, "500 Bad STOR syntax\n");
                }
            } else if (strncmp(line, "RETR ", 5) == 0) {
                char fname[256];
                if (sscanf(line + 5, "%255s", fname) == 1) {
                    printf("Client wants download: %s\n", fname);
                    handle_retr(client, fname);
                } else {
                    send_line(client, "500 Bad RETR syntax\n");
                }
            } else if (strncmp(line, "QUIT", 4) == 0) {
                send_line(client, "221 Bye\n");
                printf("Client quit.\n");
                break;
            } else {
                // Unknown line; print it
                printf("Client (raw): %s", line);
            }
        }

        // Server operator typing -> send chat to client
        if (FD_ISSET(STDIN_FILENO, &rfds)) {
            if (!fgets(line, sizeof(line), stdin)) break;

            // Server supports local commands too:
            // /quit, /put, /get handled on client side only (server is authoritative)
            if (strncmp(line, "/quit", 5) == 0) {
                send_line(client, "QUIT\n");
                break;
            }

            // Default: send as chat
            char out[LINE_MAX + 8];
            snprintf(out, sizeof(out), "MSG %s", line);
            if (send_line(client, out) < 0) {
                printf("Send failed.\n");
                break;
            }
        }
    }

    close(client);
    close(listener);
    return 0;
}

