import os, json, socket, struct
from cryptography.hazmat.primitives.asymmetric import x25519, ed25519
from cryptography.hazmat.primitives import hashes, serialization
from cryptography.hazmat.primitives.kdf.hkdf import HKDF
from cryptography.hazmat.primitives.ciphers.aead import AESGCM

HOST = "127.0.0.1"
PORT = 4444

def send_frame(conn, obj: dict):
    data = json.dumps(obj).encode()
    conn.sendall(struct.pack("!I", len(data)) + data)

def recv_frame(conn) -> dict:
    hdr = conn.recv(4)
    if not hdr:
        raise ConnectionError("closed")
    (n,) = struct.unpack("!I", hdr)
    data = b""
    while len(data) < n:
        chunk = conn.recv(n - len(data))
        if not chunk:
            raise ConnectionError("closed")
        data += chunk
    return json.loads(data.decode())

def load_server_signing_key():
    with open("server_signing_key.pem", "rb") as f:
        return serialization.load_pem_private_key(f.read(), password=None)

def hkdf_key(shared_secret: bytes, salt: bytes) -> bytes:
    return HKDF(
        algorithm=hashes.SHA256(),
        length=32,
        salt=salt,
        info=b"secure-socket-demo-v1",
    ).derive(shared_secret)

def main():
    signing_sk = load_server_signing_key()

    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.bind((HOST, PORT))
    s.listen(1)
    print(f"[server] listening on {HOST}:{PORT}")

    conn, addr = s.accept()
    print("[server] client connected:", addr)

    # --- Handshake: server ECDH ephemeral + signature ---
    server_eph_sk = x25519.X25519PrivateKey.generate()
    server_eph_pk = server_eph_sk.public_key().public_bytes(
        encoding=serialization.Encoding.Raw,
        format=serialization.PublicFormat.Raw
    )
    server_nonce = os.urandom(16)

    signature = signing_sk.sign(server_eph_pk + server_nonce)

    send_frame(conn, {
        "type": "SERVER_HELLO",
        "server_eph_pk": server_eph_pk.hex(),
        "server_nonce": server_nonce.hex(),
        "sig": signature.hex()
    })

    msg = recv_frame(conn)
    if msg.get("type") != "CLIENT_HELLO":
        raise ValueError("bad handshake")

    client_eph_pk = bytes.fromhex(msg["client_eph_pk"])
    client_nonce = bytes.fromhex(msg["client_nonce"])

    client_pub = x25519.X25519PublicKey.from_public_bytes(client_eph_pk)
    shared = server_eph_sk.exchange(client_pub)

    salt = server_nonce + client_nonce
    key = hkdf_key(shared, salt)
    aead = AESGCM(key)

    print("[server] handshake complete, secure channel ready")

    recv_counter = -1
    send_counter = 0

    while True:
        pkt = recv_frame(conn)
        if pkt.get("type") != "DATA":
            continue

        nonce = bytes.fromhex(pkt["nonce"])
        ct = bytes.fromhex(pkt["ciphertext"])
        counter = pkt["counter"]

        # replay protection
        if counter <= recv_counter:
            print("[server] replay detected, dropping")
            continue
        recv_counter = counter

        try:
            pt = aead.decrypt(nonce, ct, None)
        except Exception:
            print("[server] auth failed / tampered packet")
            continue

        text = pt.decode(errors="replace")
        print(f"[client] {text}")

        if text.strip().lower() == "quit":
            print("[server] closing")
            break

        reply = f"ACK: {text}".encode()
        # 12-byte nonce for AESGCM
        out_nonce = send_counter.to_bytes(12, "big")
        out_ct = aead.encrypt(out_nonce, reply, None)

        send_frame(conn, {
            "type": "DATA",
            "counter": send_counter,
            "nonce": out_nonce.hex(),
            "ciphertext": out_ct.hex()
        })
        send_counter += 1

    conn.close()
    s.close()

if __name__ == "__main__":
    main()

