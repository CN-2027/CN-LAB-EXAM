#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <unistd.h>
#include <arpa/inet.h>

#define PORT 8080
#define BUF_SIZE 1024

int main() {
    int server_fd, client_fd;
    struct sockaddr_in server_addr, client_addr;
    socklen_t client_len = sizeof(client_addr);

    char send_buf[BUF_SIZE], recv_buf[BUF_SIZE];

    // 1) Create socket
    server_fd = socket(AF_INET, SOCK_STREAM, 0);
    if (server_fd < 0) {
        perror("socket");
        return 1;
    }

    // (Optional) Reuse address to avoid "Address already in use"
    int opt = 1;
    setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));

    // 2) Bind
    server_addr.sin_family = AF_INET;
    server_addr.sin_addr.s_addr = inet_addr("127.0.0.1"); // localhost (WSL)
    server_addr.sin_port = htons(PORT);

    if (bind(server_fd, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {
        perror("bind");
        close(server_fd);
        return 1;
    }

    // 3) Listen
    if (listen(server_fd, 1) < 0) {
        perror("listen");
        close(server_fd);
        return 1;
    }

    printf("Server listening on 127.0.0.1:%d...\n", PORT);

    // 4) Accept
    client_fd = accept(server_fd, (struct sockaddr*)&client_addr, &client_len);
    if (client_fd < 0) {
        perror("accept");
        close(server_fd);
        return 1;
    }

    printf("Client connected!\n");
    printf("Type 'exit' to close.\n");

    while (1) {
        // Receive from client
        memset(recv_buf, 0, BUF_SIZE);
        int n = recv(client_fd, recv_buf, BUF_SIZE - 1, 0);
        if (n <= 0) {
            printf("Client disconnected.\n");
            break;
        }
        recv_buf[n] = '\0';
        printf("Client: %s\n", recv_buf);

        if (strncmp(recv_buf, "exit", 4) == 0) {
            printf("Client ended chat.\n");
            break;
        }

        // Send to client
        printf("You (Server): ");
        fflush(stdout);

        if (!fgets(send_buf, BUF_SIZE, stdin)) break;
        send_buf[strcspn(send_buf, "\n")] = '\0'; // remove newline

        if (send(client_fd, send_buf, strlen(send_buf), 0) < 0) {
            perror("send");
            break;
        }

        if (strncmp(send_buf, "exit", 4) == 0) {
            printf("Server ended chat.\n");
            break;
        }
    }

    close(client_fd);
    close(server_fd);
    return 0;
}


